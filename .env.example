# General
OCR_PROJECT_NAME=frontier-ocr API
OCR_LOG_LEVEL=INFO
OCR_PADDLE_MAX_REQUESTS_BEFORE_RELOAD=20

# Upload controls
OCR_MAX_UPLOAD_BYTES=52428800
OCR_UPLOAD_CHUNK_BYTES=1048576
OCR_MAX_PDF_PAGES=50

# PaddleOCR-VL pipeline controls
OCR_DEVICE=auto
OCR_VL_REC_MODEL_DIR=

# Optional remote inference service
OCR_VL_REC_BACKEND=
OCR_VL_REC_SERVER_URL=